# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api
CORS_ORIGIN=*
MAX_UPLOAD_SIZE_MB=20
TEMP_STORAGE_DIR=./tmp
ML_SERVICE_URL=http://127.0.0.1:8001
REQUIRE_PYTHON_ML_SERVICE=false
STRICT_REMOTE_SERVICES=false

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Artifact storage
ARTIFACT_STORAGE_MODE=disabled
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=

# Google connectors
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connectors/google/callback
GOOGLE_REFRESH_TOKEN=
GOOGLE_WORKSPACE_USER=me
APP_BASE_URL=http://localhost:5173
GOOGLE_DRIVE_FOLDER_IDS=
GOOGLE_DRIVE_WEBHOOK_URL=
GOOGLE_DRIVE_WATCH_ENABLED=false
GOOGLE_DRIVE_WATCH_CHANNEL_TOKEN=
GOOGLE_DRIVE_WATCH_EXPIRATION_MS=604800000
GOOGLE_DRIVE_WATCH_RENEWAL_LEAD_MS=21600000
GOOGLE_DRIVE_WATCH_RENEWAL_CHECK_MS=3600000
GMAIL_DEFAULT_QUERY=has:attachment filename:pdf newer_than:30d
GMAIL_POLL_ENABLED=false
GMAIL_POLL_INTERVAL_MS=300000
GMAIL_POLL_MAX_RESULTS=10
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_EMAIL_RECIPIENTS=

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=contracts
PINECONE_CONTRACT_NAMESPACE=contracts
PINECONE_PRECEDENT_NAMESPACE=precedents
PINECONE_KNOWLEDGE_NAMESPACE=knowledge
EMBEDDING_DIMENSION=128

# Firestore collections for deployed precedent/rule storage
PRECEDENT_COLLECTION=precedents
KNOWLEDGE_COLLECTION=knowledge_documents

# GenAI
GENAI_PROVIDER=template
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
RULEBOOK_PATH=./data/rulebook.json
