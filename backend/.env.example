# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173
MAX_UPLOAD_SIZE_MB=20
TEMP_STORAGE_DIR=./tmp

# Python ML service
ML_SERVICE_URL=http://127.0.0.1:8001
REQUIRE_PYTHON_ML_SERVICE=false

# Firebase
# You can either point to a service account JSON file or fill the inline fields below.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Google Drive + Gmail connectors
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_WORKSPACE_USER=me
GOOGLE_DRIVE_FOLDER_IDS=
GMAIL_DEFAULT_QUERY=has:attachment filename:pdf newer_than:30d

# Pinecone vector database
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=contracts
EMBEDDING_DIMENSION=128

# Optional external reasoning provider
GENAI_PROVIDER=template
GENAI_BASE_URL=
GENAI_API_KEY=
GENAI_MODEL=

# Local rulebook
RULEBOOK_PATH=./data/rulebook.json
